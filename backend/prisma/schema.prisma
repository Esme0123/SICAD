// ============================================================
// SICAD - Sistema de Control de Asistencia
// Prisma Schema — PostgreSQL (Neon.tech)
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ============================================================
// ENUMS
// ============================================================

enum Rol {
  ADMIN
  EMPLEADO
}

enum EstadoPermiso {
  PENDIENTE
  APROBADO
  RECHAZADO
}

// ============================================================
// USUARIO (Empleados y Administradores)
// ============================================================

model Usuario {
  id                Int                @id @default(autoincrement())
  nombre            String
  email             String             @unique
  password          String
  rol               Rol                @default(EMPLEADO)

  /// Meta de horas semanales/quincenales (ej. 20 o 40)
  horasBase         Int                @default(40)

  /// Sumatoria automática de horas asignadas en HorarioAsignado
  /// Se recalcula en la aplicación cada vez que se modifica el horario
  horasProgramadas  Float              @default(0)

  codigo            String?            @unique
  ci                String?
  celular           String?
  activo            Boolean            @default(true)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relaciones
  horariosAsignados HorarioAsignado[]
  asistencias       Asistencia[]
  permisos          Permiso[]
  notificaciones    Notificacion[]

  @@map("usuarios")
}

// ============================================================
// GESTIÓN ACADÉMICA (Periodo Contrato)
// Permite escalar el sistema a través de múltiples gestiones
// sin perder el histórico de horarios y asistencias.
// Ej: "1-2026", "Invierno 2026", "2-2026"
// ============================================================

model GestionAcademica {
  id          Int                @id @default(autoincrement())
  nombre      String
  fechaInicio DateTime           @db.Date
  fechaFin    DateTime           @db.Date
  activo      Boolean            @default(false)

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  /// Solo una gestión puede estar activa a la vez (validar en la app)
  horariosAsignados HorarioAsignado[]

  @@map("gestiones_academicas")
}

// ============================================================
// CATÁLOGO DE PERIODOS
// Bloques de tiempo de la universidad
// Ej: { horaInicio: "07:15", horaFin: "08:15", nombre: "Bloque 1" }
// ============================================================

model Periodo {
  id          Int                @id @default(autoincrement())
  nombre      String             // Ej: "Bloque 1", "Bloque 2"
  horaInicio  String             // Formato "HH:mm" — Ej: "07:15"
  horaFin     String             // Formato "HH:mm" — Ej: "08:15"
  duracion    Int                // Duración en minutos (calculada)
  activo      Boolean            @default(true)

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relaciones
  horariosAsignados HorarioAsignado[]
  permisoPeriodos   PermisoPeriodo[]

  @@map("periodos")
}

// ============================================================
// HORARIO ASIGNADO
// Relaciona Usuario <-> Periodo con un día de la semana
// Un usuario puede tener múltiples periodos por día
// ============================================================

model HorarioAsignado {
  id          Int               @id @default(autoincrement())

  usuarioId   Int
  usuario     Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  periodoId   Int
  periodo     Periodo           @relation(fields: [periodoId], references: [id], onDelete: Restrict)

  gestionId   Int?
  gestion     GestionAcademica? @relation(fields: [gestionId], references: [id], onDelete: Restrict)

  /// "Lunes" | "Martes" | "Miercoles" | "Jueves" | "Viernes" | "Sabado"
  diaSemana   String

  /// Ej: "1-2026", "Invierno 2026", "Verano 2026"
  periodoAcademico String

  createdAt   DateTime          @default(now())

  @@unique([usuarioId, periodoId, diaSemana, periodoAcademico])
  @@map("horarios_asignados")
}

// ============================================================
// ASISTENCIA
// Lógica de bloques continuos:
//   - Un usuario puede registrar VARIAS asistencias por día
//   - Escanea al inicio del primer bloque continuo (horaEntrada)
//   - Escanea al final del último bloque continuo (horaSalida)
//   - horaSalida es nullable hasta que el empleado cierre el turno
// ============================================================

model Asistencia {
  id          Int       @id @default(autoincrement())

  usuarioId   Int
  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  /// Solo la fecha (sin hora), permite agrupar bloques del mismo día
  fecha       DateTime  @db.Date

  horaEntrada DateTime
  horaSalida  DateTime?  // Nullable: se rellena cuando el empleado escanea al salir

  /// true cuando el cronjob cierra el turno automáticamente (el empleado olvidó marcar salida)
  salidaOmitida Boolean @default(false)

  /// Minutos de tolerancia aplicados en este registro (para auditoría)
  minutosTolerancia Int @default(0)

  /// Observaciones opcionales (tardanza, permiso parcial, etc.)
  observacion String?

  /// Bloque de periodo oficial asignado (ej. "07:15–08:15")
  periodo String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("asistencias")
}

// ============================================================
// CATÁLOGO DE TIPOS DE PERMISO
// Ej: "Baja médica", "Permiso personal", "Vacaciones"
// ============================================================

model TipoPermiso {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  activo      Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relaciones
  permisos    Permiso[]

  @@map("tipos_permiso")
}

// ============================================================
// PERMISO
// Solicitudes de ausencia vinculadas a Usuario y TipoPermiso
// ============================================================

model Permiso {
  id             Int           @id @default(autoincrement())

  usuarioId      Int
  usuario        Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  tipoPermisoId  Int
  tipoPermiso    TipoPermiso   @relation(fields: [tipoPermisoId], references: [id], onDelete: Restrict)

  /// Fecha del día en que aplica el permiso (puede ser parcial: solo algunos periodos)
  fecha          DateTime      @db.Date
  motivo         String
  estado         EstadoPermiso @default(PENDIENTE)

  /// Explicación ingresada por el empleado al solicitar el permiso
  observacion    String?

  /// Ruta del archivo o imagen adjunta subida por el empleado
  adjuntoUrl     String?

  /// ID del administrador que aprobó/rechazó
  revisadoPor    Int?
  fechaRevision  DateTime?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relación con los periodos afectados por este permiso
  periodos       PermisoPeriodo[]

  @@map("permisos")
}

// ============================================================
// PERMISO PERIODO
// Tabla intermedia: un permiso puede cubrir 1, 2 o N periodos
// del mismo día (permiso parcial)
// ============================================================

model PermisoPeriodo {
  id          Int     @id @default(autoincrement())

  permisoId   Int
  permiso     Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  periodoId   Int
  periodo     Periodo @relation(fields: [periodoId], references: [id], onDelete: Restrict)

  // Un permiso no puede registrar el mismo periodo dos veces
  @@unique([permisoId, periodoId])
  @@map("permiso_periodos")
}

// ============================================================
// CONFIGURACIÓN DEL SISTEMA
// Una sola fila (id = 1). Se usa upsert desde la app.
// Campos extraídos directamente de la UI de configuración.
// ============================================================

model ConfiguracionSistema {
  id                Int      @id @default(1)

  nombreInstitucion String   @default("SICAD")

  /// "xlsx" | "csv" | "pdf"
  formatoExportacion String  @default("xlsx")

  /// Minutos de gracia antes de marcar tardanza
  tiempoTolerancia   Int     @default(10)

  /// Tiempo de vida del código QR en segundos
  duracionQR         Int     @default(30)

  /// Hora de inicio del control de asistencia (formato "HH:mm")
  horaApertura       String  @default("06:00")

  /// Hora de cierre del control de asistencia (formato "HH:mm")
  horaCierre         String  @default("22:00")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("configuracion_sistema")
}

// ============================================================
// USUARIO DEL SISTEMA (Login Dashboard)
// Exclusivo para quienes acceden al panel web.
// Separado del modelo Empleado (asistencia por QR).
// ============================================================

enum RolSistema {
  ADMIN
  COORDINADOR
}

model UsuarioSistema {
  id           Int        @id @default(autoincrement())
  nombre       String
  email        String     @unique
  passwordHash String
  rol          RolSistema @default(ADMIN)
  activo       Boolean    @default(true)
  codigo       String?    @unique
  ci           String?
  celular      String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("usuarios_sistema")
}

// ============================================================
// AUDITORÍA DEL SISTEMA
// Registro cronológico de acciones importantes.
// ============================================================

model Auditoria {
  id           Int      @id @default(autoincrement())
  accion       String
  usuarioEmail String
  fechaHora    DateTime @default(now())
  direccionIP  String

  @@map("auditoria")
}

model QrNonce {
  nonce     String   @id
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("qr_nonces")
}

// ============================================================
// NOTIFICACIÓN
// Alertas del sistema para empleados y administradores.
// Ej: "Tu permiso fue APROBADO", "Nueva solicitud de permiso"
// ============================================================

model Notificacion {
  id        Int      @id @default(autoincrement())

  /// Destinatario (null = para todos los ADMIN/COORDINADOR)
  usuarioId Int?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  titulo    String
  mensaje   String
  leida     Boolean  @default(false)

  /// "ADMIN" | "EMPLEADO" | "SISTEMA"
  paraRol   String   @default("EMPLEADO")

  /// ID del permiso relacionado (para enlace rápido)
  permisoId Int?

  createdAt DateTime @default(now())

  @@map("notificaciones")
}

